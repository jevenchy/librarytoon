    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "lru-cache": "^11.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.4.0",
    "react-router-dom": "^6.27.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
