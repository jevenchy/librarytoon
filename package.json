{
  "name": "librarytoon",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development node --watch-path=./server --watch-path=./shared --import=tsx/esm server/index.ts",
