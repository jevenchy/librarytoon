{
  "$schema": "../../shared/sources.schema.json",
  "id": "kaynscan",
  "baseUrl": "https://kaynscan.org",
  "method": "html",
  "urlFormat": "slug",
  "seriesUrl": "/series/",
  "chapterUrl": "/chapter/",
  "selectors": {
    "chapterTitle": ".text-sm.truncate",
    "chapterDateAttr": "d",
    "pageImage": "img[uid]",
    "imageAttr": "uid",
    "seriesDescription": "#expand_content p",
    "seriesType": "span.text-xs.font-medium.inline-block.border",
    "seriesAltTitleAstroKey": "alternativeTitles"
  },
  "proxyImages": true,
  "images": {
    "urlPattern": "^(?!https?://)(.+)$",
    "urlReplacement": "https://cdn.meowing.org/uploads/$1"
  },
  "search": {
    "listingUrl": "/series/",
    "ajaxFallback": false
  },
  "nestedChapterIds": true,
  "color": "#2563eb",
  "contentRating": "sfw",
  "language": "en",
  "enabled": true
}
