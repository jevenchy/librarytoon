{
  "$schema": "../../shared/sources.schema.json",
  "id": "writerscans",
  "baseUrl": "https://writerscans.com",
  "method": "html",
  "urlFormat": "uuid",
  "seriesUrl": "/series/",
  "chapterUrl": "/chapter/",
  "selectors": {
    "searchItem": "button[id][data-type]",
    "chapterItem": "a[href*='/chapter/']",
    "chapterDateAttr": "d",
    "pageImage": "img[uid]",
    "imageAttr": "uid",
    "seriesGenres": "a[href*='?genre=']",
    "seriesType": "div.uppercase",
    "seriesAltTitle": "span.leading-none"
  },
  "proxyImages": true,
  "imageReferer": "https://writerscans.com",
  "images": {
    "urlPattern": "^([A-Za-z0-9_-]+)$",
    "urlReplacement": "https://cdn.meowing.org/uploads/$1"
  },
  "search": {
    "endpoints": ["/series/?q={q}"],
    "ajaxFallback": false,
    "listingFallback": false
  },
  "color": "#6366f1",
  "contentRating": "sfw",
  "language": "en",
  "enabled": true
}
